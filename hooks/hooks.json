{
  "description": "Orchestrator Agent hooks - task completion enforcement, verification, polling",
  "_note": "Hook data is passed via stdin as JSON. Scripts read from stdin, not env vars.",
  "hooks": {
    "Stop": [
      {
        "_id": "amoa-orchestrator-stop",
        "_description": "Blocks premature exit until all tasks are complete",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/amoa_stop_check/main.py",
            "timeout": 120000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_id": "amoa-instruction-verification-check",
        "_description": "MANDATORY: Blocks agent work reports if instruction verification incomplete",
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/amoa_check_verification_status.py",
            "timeout": 30000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_id": "amoa-polling-reminder",
        "_description": "MANDATORY: Reminds orchestrator when progress polling is overdue",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/amoa_check_polling_due.py",
            "timeout": 30000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_id": "amoa-file-tracker",
        "_description": "Track file modifications for orchestration context",
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/amoa_file_tracker.py",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
